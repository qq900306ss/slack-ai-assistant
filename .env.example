# Slack credentials
SLACK_APP_TOKEN=xapp-...      # Socket Mode token (starts with xapp-)
SLACK_USER_TOKEN=xoxp-...     # User token with required scopes

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slack_assistant?sslmode=disable

# Ingest settings
BACKFILL_DAYS=30
SLACK_EXCLUDE_CHANNELS=        # Comma-separated channel IDs to exclude

# OpenAI (required for embeddings, optional for agent)
OPENAI_API_KEY=sk-...                    # OpenAI API key
EMBEDDING_MODEL=text-embedding-3-small   # or text-embedding-3-large
EMBEDDING_BATCH_SIZE=32                  # Messages per batch (max 2048)

# AI Backend for agent (choose one)
AI_BACKEND=openai                        # "openai" or "anthropic"
OPENAI_MODEL=gpt-4o-mini                 # For openai backend: gpt-4o-mini, gpt-4o, etc.
ANTHROPIC_API_KEY=sk-ant-...             # For anthropic backend
ANTHROPIC_MODEL=claude-sonnet-4-20250514 # claude-sonnet-4-20250514, claude-haiku-3-5-20250603, etc.

# Reindex options
FORCE_REINDEX=false                      # Set to true to reset all backfill states and re-fetch everything
PURGE_EXCLUDED_ON_SYNC=false             # Set to true to delete data from excluded channels on startup
