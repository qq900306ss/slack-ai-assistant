# Slack credentials
SLACK_APP_TOKEN=xapp-...      # Socket Mode token (starts with xapp-)
SLACK_USER_TOKEN=xoxp-...     # User token with required scopes

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slack_assistant?sslmode=disable

# Ingest settings
BACKFILL_DAYS=30
SLACK_EXCLUDE_CHANNELS=        # Comma-separated channel IDs to exclude

# Optional: Anthropic (for M4+)
# ANTHROPIC_API_KEY=sk-ant-...
